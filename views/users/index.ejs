<!DOCTYPE html>
<html>

<head>
    <title>Users</title>
</head>

<body>

    <h1>Gestion des utilisateurs</h1>

    <a href="/dashboard/users/new">➕ Ajouter</a>

    <table border="1" width="100%">
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Rôle</th>
            <th>Actions</th>
        </tr>

        <% if (users && users.length > 0) { %>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.role %></td>
                    <td>
                        <a href="/dashboard/users/edit/<%= user._id %>">Modifier</a>

                        <form action="/dashboard/users/delete/<%= user._id %>" method="POST" style="display:inline;">
                            <button type="submit">Supprimer</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="4" style="text-align:center;">
                    Aucun utilisateur trouvé
                </td>
            </tr>
        <% } %>

    </table>

</body>

</html>