<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Modifier un catway</title>
</head>

<body>

    <h1>Modifier l'état du catway</h1>

    <p>
        <strong>Numéro :</strong> <%= catway.catwayNumber %>
    </p>

    <p>
        <strong>Type :</strong> <%= catway.catwayType %>
    </p>

    <form action="/dashboard/catways/edit/<%= catway._id %>" method="POST">

        <label for="catwayState">État du catway</label><br>

        <textarea
            id="catwayState"
            name="catwayState"
            rows="4"
            cols="40"
            required><%= catway.catwayState %></textarea>

        <br><br>

        <button type="submit">
            Modifier l'état
        </button>

    </form>

</body>

</html>