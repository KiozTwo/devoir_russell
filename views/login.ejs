<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Port de plaisance Russell</title>
</head>

<body>
<h1>Port de plaisance Russell</h1>

<p>
    Bienvenue sur l'application de gestion du port de plaisance Russell.
    Connectez-vous pour accéder au tableau de bord et gérer les utilisateurs,
    les catways et les réservations.
</p>

    <hr>

    <h2>Connexion</h2>

    <!-- IMPORTANT : route backend -->
    <form action="/auth/login" method="POST">

        <div>
            <label>Email :</label><br>
            <input type="email" name="email" required>
        </div>

        <br>

        <div>
            <label>Mot de passe :</label><br>
            <input type="password" name="password" required>
        </div>

        <br>

        <button type="submit">
            Se connecter
        </button>

    </form>

    <hr>

    <p>
        <a href="/api-docs">
            Documentation de l'API
        </a>
    </p>

</body>

</html>