<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <style>
        body { font-family: Arial; margin: 40px; }
        table { border-collapse: collapse; width: 100%; }
        table, th, td { border: 1px solid black; }
        th, td { padding: 10px; text-align: center; }
        ul { list-style: none; padding: 0; }
        li { margin-bottom: 10px; }
    </style>
</head>

<body>

<h1>Tableau de bord</h1>

<hr>

<h2>Utilisateur connecté</h2>

<p><strong>Email :</strong> <%= user?.email %></p>
<p><strong>Date :</strong> <%= today.toLocaleDateString('fr-FR') %></p>

<hr>

<h2>Navigation</h2>

<ul>
    <li><a href="/dashboard/users">Gestion des utilisateurs</a></li>
    <li><a href="/dashboard/catways">Gestion des Catways</a></li>
    <li><a href="/dashboard/reservations">Gestion des Réservations</a></li>
    <li><a href="/api-docs">Documentation API</a></li>
    <li><a href="/logout">Déconnexion</a></li>
</ul>

<hr>

<h2>Réservations en cours</h2>

<table>
    <thead>
        <tr>
            <th>Client</th>
            <th>Bateau</th>
            <th>Catway</th>
            <th>Date début</th>
            <th>Date fin</th>
        </tr>
    </thead>

    <tbody>
        <% if (!reservations || reservations.length === 0) { %>
            <tr>
                <td colspan="5">Aucune réservation</td>
            </tr>
        <% } else { %>
            <% reservations.forEach(r => { %>
                <tr>
                    <td><%= r.clientName %></td>
                    <td><%= r.boatName %></td>
                    <td><%= r.catway?.catwayNumber || "Supprimé" %></td>
                    <td><%= r.startDate ? new Date(r.startDate).toLocaleDateString('fr-FR') : "-" %></td>
                    <td><%= r.endDate ? new Date(r.endDate).toLocaleDateString('fr-FR') : "-" %></td>
                </tr>
            <% }) %>
        <% } %>
    </tbody>
</table>

</body>
</html>